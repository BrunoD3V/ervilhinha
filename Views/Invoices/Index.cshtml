@model IEnumerable<Ervilhinha.Models.Invoice>

@{
    ViewData["Title"] = "Faturas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📄 Scanner de Faturas @(ViewBag.OcrConfigured == false ? "(Modo Manual)" : "")</h1>
    <a asp-action="Upload" class="btn btn-primary">📸 Carregar Fatura</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show">
        @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-3">
    <div class="col-md-12">
        @if (ViewBag.OcrConfigured == false)
        {
            <div class="alert alert-warning">
                <h5>⚠️ Modo Manual Ativo</h5>
                <p class="mb-2">
                    <strong>Azure Document Intelligence não está configurado.</strong>
                    As faturas serão carregadas mas os dados terão de ser inseridos manualmente.
                </p>
                <p class="mb-0">
                    💡 Para ativar leitura automática: <code>Documentation/Invoice-OCR-Roadmap.md</code>
                </p>
            </div>
        }
        else
        {
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5>🤖 Processamento de Faturas com IA - ATIVO ✅</h5>
                    <p class="mb-0">Carrega imagens ou PDFs de faturas e deixa a IA extrair automaticamente o fornecedor, data e montante. Revê e aprova para criação automática de despesas!</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Pré-visualização</th>
                            <th>Fornecedor</th>
                            <th>Montante</th>
                            <th>Data</th>
                            <th>Estado</th>
                            <th>Carregado</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model)
                        {
                            <tr class="@(invoice.HasErrors ? "table-warning" : (invoice.IsReviewed ? "table-success" : ""))">
                                <td>
                                    @if (!string.IsNullOrEmpty(invoice.FilePath))
                                    {
                                        <a href="@invoice.FilePath" target="_blank">
                                            <img src="@invoice.FilePath" alt="Fatura" style="max-width: 60px; max-height: 60px;" class="img-thumbnail" />
                                        </a>
                                    }
                                </td>
                                <td>
                                    <strong>@(invoice.VendorName ?? "Desconhecido")</strong>
                                    <br />
                                    <small class="text-muted">@invoice.FileName</small>
                                </td>
                                <td>
                                    @if (invoice.TotalAmount.HasValue)
                                    {
                                        <strong>€@invoice.TotalAmount.Value.ToString("N2")</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Não detetado</span>
                                    }
                                </td>
                                <td>@(invoice.InvoiceDate?.ToShortDateString() ?? "Não detetado")</td>
                                <td>
                                    @if (invoice.IsReviewed)
                                    {
                                        <span class="badge bg-success">✓ Revisto</span>
                                    }
                                    else if (invoice.HasErrors)
                                    {
                                        <span class="badge bg-warning">⚠ Precisa Revisão</span>
                                    }
                                    else if (invoice.IsProcessed)
                                    {
                                        <span class="badge bg-info">📝 Processado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pendente</span>
                                    }

                                    @if (invoice.Expense != null)
                                    {
                                        <br />
                                        <span class="badge bg-primary">💰 Despesa Criada</span>
                                    }
                                </td>
                                <td>
                                    <small>@invoice.UploadDate.ToLocalTime().ToString("g")</small>
                                    <br />
                                    <small class="text-muted">por @invoice.UploadedBy</small>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Review" asp-route-id="@invoice.Id" class="btn btn-warning">
                                            @if (invoice.IsReviewed)
                                            {
                                                <text>Ver</text>
                                            }
                                            else
                                            {
                                                <text>Rever</text>
                                            }
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@invoice.Id" class="btn btn-danger">Eliminar</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <h4>Ainda não tens faturas carregadas</h4>
                <p>Clica em "Carregar Fatura" para começar o processamento de faturas com IA!</p>
            </div>
        }
    </div>
</div>
