<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ervilhinha 🌿</title>

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.svg">
    <link rel="apple-touch-icon" href="~/favicon.svg">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms-modern.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms-epic.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ervilhinha.styles.css" asp-append-version="true" />
</head>
<body class="internal-pages">
    <header>
        @{ ViewData["NavbarContainerClass"] = "main-layout-container"; }
        <partial name="_NavBar" />
    </header>
    <div class="main-layout-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="main-layout-container">
            &copy; 2026 - Ervilhinha - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidade</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- HTMX - Modern HTML-over-the-wire -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/epic-effects.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
