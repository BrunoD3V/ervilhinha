@model Ervilhinha.Models.BabyTimeline

@{
    ViewData["Title"] = "Editar Evento";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-1">✏️ Editar Evento</h3>
                        <p class="text-soft small mb-0">@Model.Title</p>
                    </div>
                    <a asp-action="Index" class="btn btn-secondary">← Voltar</a>
                </div>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="CreatedDate" />
                    
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Title" class="form-label">Título do Evento *</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="EventDate" class="form-label">Data</label>
                            <input asp-for="EventDate" type="date" class="form-control" />
                            <span asp-validation-for="EventDate" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Type" class="form-label">Tipo de Evento *</label>
                            <select asp-for="Type" asp-items="Html.GetEnumSelectList<Ervilhinha.Models.TimelineEventType>()" class="form-select">
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Phase" class="form-label">Fase *</label>
                            <select asp-for="Phase" asp-items="Html.GetEnumSelectList<Ervilhinha.Models.BabyPhase>()" class="form-select">
                            </select>
                            <span asp-validation-for="Phase" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Priority" class="form-label">Prioridade</label>
                            <select asp-for="Priority" asp-items="Html.GetEnumSelectList<Ervilhinha.Models.TimelinePriority>()" class="form-select">
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="PregnancyWeek" class="form-label">Semana de Gravidez</label>
                            <input asp-for="PregnancyWeek" type="number" min="0" max="42" class="form-control" />
                            <span asp-validation-for="PregnancyWeek" class="text-danger"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="BabyMonthAge" class="form-label">Mês de Vida do Bebé</label>
                            <input asp-for="BabyMonthAge" type="number" min="0" max="12" class="form-control" />
                            <span asp-validation-for="BabyMonthAge" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Descrição</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="EstimatedCost" class="form-label">Custo Estimado (€)</label>
                            <input asp-for="EstimatedCost" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="EstimatedCost" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ActualCost" class="form-label">Custo Real (€)</label>
                            <input asp-for="ActualCost" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="ActualCost" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ReminderDaysBefore" class="form-label">Lembrar X dias antes</label>
                            <input asp-for="ReminderDaysBefore" type="number" min="0" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CompletedDate" class="form-label">Data de Conclusão</label>
                            <input asp-for="CompletedDate" type="date" class="form-control" />
                        </div>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="HasReminder" class="form-check-input" type="checkbox" />
                        <label asp-for="HasReminder" class="form-check-label">
                            🔔 Ativar lembrete para este evento
                        </label>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="IsCompleted" class="form-check-input" type="checkbox" />
                        <label asp-for="IsCompleted" class="form-check-label">
                            ✅ Marcar como concluído
                        </label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">💾 Guardar Alterações</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
