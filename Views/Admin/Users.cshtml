@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Gestão de Utilizadores";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title">👥 Gestão de Utilizadores</h1>
        <p class="text-soft mb-0">Administra permissões e funções dos utilizadores da aplicação</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary" id="simulateUserView" title="Simular Vista de Utilizador Normal">
            <i class="bi bi-eye"></i> Simular Vista User
        </a>
        <span class="badge bg-info" style="font-size: 1rem; padding: 0.5rem 1rem;">
            @Model.Count() utilizador@(Model.Count() != 1 ? "es" : "") registado@(Model.Count() != 1 ? "s" : "")
        </span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>✅ Sucesso!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>❌ Erro!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<!-- Tabela de Utilizadores -->
<div class="card card-blue shadow">
    <div class="card-header bg-transparent border-0 pt-4 px-4">
        <h5 class="mb-0">📋 Lista de Utilizadores</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th><i class="bi bi-envelope"></i> Email</th>
                        <th><i class="bi bi-person"></i> Nome de Utilizador</th>
                        <th class="text-center"><i class="bi bi-check-circle"></i> Email Verificado</th>
                        <th class="text-center"><i class="bi bi-shield-check"></i> Funções</th>
                        <th class="text-center">⚙️ Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var userRoles = ViewBag.UserRoles[user.Id] as IList<string>;
                        var isAdmin = userRoles?.Contains("Admin") ?? false;
                        var isUser = userRoles?.Contains("User") ?? false;

                        <tr>
                            <td>
                                <strong>@user.Email</strong>
                                @if (user.Id == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <span class="badge bg-warning text-dark ms-2">Tu</span>
                                }
                            </td>
                            <td>@user.UserName</td>
                            <td class="text-center">
                                @if (user.EmailConfirmed)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-check-circle-fill"></i> Verificado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-clock"></i> Pendente
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @if (isAdmin)
                                {
                                    <span class="badge bg-danger me-1">
                                        <i class="bi bi-shield-fill-check"></i> Admin
                                    </span>
                                }
                                @if (isUser)
                                {
                                    <span class="badge bg-primary">
                                        <i class="bi bi-person-fill"></i> Utilizador
                                    </span>
                                }
                                @if (!isAdmin && !isUser)
                                {
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-dash-circle"></i> Sem Funções
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <!-- Toggle Admin -->
                                    <form asp-action="ToggleRole" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="role" value="Admin" />
                                        <button type="submit" 
                                                class="btn btn-sm @(isAdmin ? "btn-outline-danger" : "btn-outline-success")"
                                                title="@(isAdmin ? "Remover permissões de Admin" : "Tornar Admin")">
                                            @if (isAdmin)
                                            {
                                                <span><i class="bi bi-shield-slash"></i> Remover Admin</span>
                                            }
                                            else
                                            {
                                                <span><i class="bi bi-shield-plus"></i> Tornar Admin</span>
                                            }
                                        </button>
                                    </form>

                                    <!-- Toggle User -->
                                    <form asp-action="ToggleRole" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="role" value="User" />
                                        <button type="submit" 
                                                class="btn btn-sm @(isUser ? "btn-outline-secondary" : "btn-outline-primary")"
                                                title="@(isUser ? "Remover função de Utilizador" : "Tornar Utilizador")">
                                            @if (isUser)
                                            {
                                                <span><i class="bi bi-person-dash"></i> Remover User</span>
                                            }
                                            else
                                            {
                                                <span><i class="bi bi-person-plus"></i> Tornar User</span>
                                            }
                                        </button>
                                    </form>

                                    <!-- Delete User -->
                                    @if (user.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                    {
                                        <form asp-action="DeleteUser" method="post" class="d-inline" 
                                              onsubmit="return confirm('⚠️ Tens a certeza que pretendes eliminar este utilizador?\n\nEsta ação é irreversível!');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" 
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Eliminar utilizador">
                                                <i class="bi bi-trash"></i> Eliminar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Não podes eliminar a tua própria conta">
                                            <i class="bi bi-lock"></i> Bloqueado
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Informação sobre Funções -->
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card card-peach shadow-sm">
            <div class="card-body">
                <h5 class="mb-3">
                    <i class="bi bi-shield-fill-check" style="color: #dc3545;"></i>
                    <strong>Admin</strong> - Acesso Total
                </h5>
                <ul class="mb-0">
                    <li>✅ Acesso completo a todas as funcionalidades</li>
                    <li>✅ Pode gerir categorias de despesas</li>
                    <li>✅ Pode eliminar quaisquer itens</li>
                    <li>✅ Pode gerir utilizadores e permissões</li>
                    <li>✅ Acesso a relatórios avançados</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-yellow shadow-sm">
            <div class="card-body">
                <h5 class="mb-3">
                    <i class="bi bi-person-fill" style="color: #0d6efd;"></i>
                    <strong>Utilizador</strong> - Acesso Standard
                </h5>
                <ul class="mb-0">
                    <li>✅ Pode visualizar e editar artigos do bebé</li>
                    <li>✅ Pode adicionar e gerir despesas</li>
                    <li>✅ Pode visualizar relatórios</li>
                    <li>✅ Pode gerir listas de desejos</li>
                    <li>⚠️ Permissões de eliminação limitadas</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Estatísticas -->
@{
    var totalUsers = Model.Count();
    var verifiedUsers = Model.Count(u => u.EmailConfirmed);
    var adminCount = Model.Count(u => (ViewBag.UserRoles[u.Id] as IList<string>)?.Contains("Admin") ?? false);
    var userCount = Model.Count(u => (ViewBag.UserRoles[u.Id] as IList<string>)?.Contains("User") ?? false);
}

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-soft">👥 Total de Utilizadores</h6>
                <h2 class="mb-0" style="color: var(--pea-green-soft);">@totalUsers</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-soft">✅ Emails Verificados</h6>
                <h2 class="mb-0" style="color: #28a745;">@verifiedUsers</h2>
                <small class="text-muted">@((verifiedUsers * 100 / totalUsers).ToString("F0"))%</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-soft">🛡️ Administradores</h6>
                <h2 class="mb-0" style="color: #dc3545;">@adminCount</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body">
                <h6 class="text-soft">👤 Utilizadores</h6>
                <h2 class="mb-0" style="color: #0d6efd;">@userCount</h2>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simular Vista de Utilizador (esconde elementos Admin temporariamente)
        document.getElementById('simulateUserView').addEventListener('click', function(e) {
            e.preventDefault();

            // Toggle simulação
            const body = document.body;
            const btn = this;

            if (body.classList.contains('user-simulation')) {
                // Voltar à vista Admin
                body.classList.remove('user-simulation');
                btn.innerHTML = '<i class="bi bi-eye"></i> Simular Vista User';
                btn.classList.remove('btn-warning');
                btn.classList.add('btn-outline-primary');
            } else {
                // Ativar vista User
                body.classList.add('user-simulation');
                btn.innerHTML = '<i class="bi bi-shield-check"></i> Vista Admin';
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-warning');

                alert('🔍 Vista de Utilizador Normal Ativada!\n\n' +
                      'Nesta simulação:\n' +
                      '✅ Menu "Categorias" e "Utilizadores" estão ocultos\n' +
                      '✅ Navegação igual à de um utilizador normal\n\n' +
                      'Clica novamente para voltar à Vista Admin.');
            }
        });

        // Confirmação de eliminação de utilizador
        document.querySelectorAll('form[action*="DeleteUser"]').forEach(form => {
            form.addEventListener('submit', function(e) {
                const email = this.closest('tr').querySelector('td:first-child').textContent.trim();
                if (!confirm(`⚠️ ATENÇÃO: Tens a certeza que queres ELIMINAR o utilizador "${email}"?\n\nEsta ação é IRREVERSÍVEL e apagará:\n• Conta do utilizador\n• Todos os dados associados\n• Histórico e registos\n\nConfirmar eliminação?`)) {
                    e.preventDefault();
                }
            });
        });

        // Confirmação de alteração de função
        document.querySelectorAll('form[action*="ToggleRole"]').forEach(form => {
            form.addEventListener('submit', function(e) {
                const email = this.closest('tr').querySelector('td:first-child').textContent.trim();
                const role = this.querySelector('input[name="role"]').value;
                const btnText = this.querySelector('button').textContent.trim();

                if (!confirm(`Confirmar alteração de função?\n\nUtilizador: ${email}\nAção: ${btnText}\n\nContinuar?`)) {
                    e.preventDefault();
                }
            });
        });
    </script>

    <style>
        /* CSS para simulação de vista User */
        body.user-simulation .nav-item a[href*="ExpenseCategories"],
        body.user-simulation .nav-item a[href*="Admin"] {
            display: none !important;
        }

        body.user-simulation .nav-item:has(a[href*="ExpenseCategories"]),
        body.user-simulation .nav-item:has(a[href*="Admin"]) {
            display: none !important;
        }
    </style>
}

