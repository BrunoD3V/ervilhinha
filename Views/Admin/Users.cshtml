@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "User Management";
}

<h1>👥 User Management</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Username</th>
                    <th>Email Confirmed</th>
                    <th>Roles</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var userRoles = ViewBag.UserRoles[user.Id] as IList<string>;
                    var isAdmin = userRoles?.Contains("Admin") ?? false;
                    var isUser = userRoles?.Contains("User") ?? false;

                    <tr>
                        <td>@user.Email</td>
                        <td>@user.UserName</td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="badge bg-success">✓ Confirmed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                        </td>
                        <td>
                            @if (isAdmin)
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            @if (isUser)
                            {
                                <span class="badge bg-primary">User</span>
                            }
                            @if (!isAdmin && !isUser)
                            {
                                <span class="badge bg-secondary">No Roles</span>
                            }
                        </td>
                        <td>
                            <form asp-action="ToggleRole" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="role" value="Admin" />
                                <button type="submit" class="btn btn-sm @(isAdmin ? "btn-warning" : "btn-success")">
                                    @(isAdmin ? "Remove Admin" : "Make Admin")
                                </button>
                            </form>
                            
                            <form asp-action="ToggleRole" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="role" value="User" />
                                <button type="submit" class="btn btn-sm @(isUser ? "btn-secondary" : "btn-primary")">
                                    @(isUser ? "Remove User" : "Make User")
                                </button>
                            </form>

                            @if (user.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                            {
                                <form asp-action="DeleteUser" method="post" class="d-inline" 
                                      onsubmit="return confirm('Are you sure you want to delete this user?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <div class="alert alert-info">
        <h5>Role Descriptions:</h5>
        <ul>
            <li><strong>Admin:</strong> Full access to all features, can manage categories, delete items, and manage users</li>
            <li><strong>User:</strong> Can view and edit baby items, add expenses, view reports (limited delete permissions)</li>
        </ul>
    </div>
</div>
