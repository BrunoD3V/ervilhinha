@model IEnumerable<Ervilhinha.Models.BabyItem>

@{
    ViewData["Title"] = "Artigos do Bebé";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>👶 Artigos do Bebé</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createBabyItemModal">
        ➕ Adicionar Novo Artigo
    </button>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="d-flex gap-2">
            <select name="category" class="form-select" onchange="this.form.submit()">
                <option value="All">Todas as Categorias</option>
                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat" selected="@(Context.Request.Query["category"] == cat)">@cat</option>
                }
            </select>
            <select name="sortBy" class="form-select" onchange="this.form.submit()">
                <option value="Priority" selected="@(Context.Request.Query["sortBy"] == "Priority")">Ordenar por Prioridade</option>
                <option value="Name" selected="@(Context.Request.Query["sortBy"] == "Name")">Ordenar por Nome</option>
                <option value="Status" selected="@(Context.Request.Query["sortBy"] == "Status")">Ordenar por Estado</option>
            </select>
        </form>
    </div>
</div>

<div class="row">
    @if (Model.Any())
    {
        <div class="col-md-6">
            <h4>🔴 Por Comprar</h4>
            <div id="babyItemsList">
            @foreach (var item in Model.Where(i => !i.IsPurchased))
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text">
                            <span class="badge bg-info">@item.Category</span>
                            <span class="badge bg-warning">Prioridade: @item.Priority</span>
                        </p>
                        @if (!string.IsNullOrEmpty(item.Description))
                        {
                            <p class="card-text">@item.Description</p>
                        }
                        @if (item.EstimatedCost.HasValue)
                        {
                            <p class="card-text"><strong>Custo Estimado:</strong> €@item.EstimatedCost.Value.ToString("N2")</p>
                        }
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <form asp-action="MarkAsPurchased" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">✓ Marcar como Comprado</button>
                            </form>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                            }
                        </div>
                    </div>
                </div>
            }
            </div>
        </div>
        <div class="col-md-6">
            <h4>✅ Comprados</h4>
            @foreach (var item in Model.Where(i => i.IsPurchased))
            {
                <div class="card mb-3 bg-light">
                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text">
                            <span class="badge bg-info">@item.Category</span>
                            <span class="badge bg-success">Comprado</span>
                        </p>
                        @if (item.ActualCost.HasValue)
                        {
                            <p class="card-text"><strong>Custo Real:</strong> €@item.ActualCost.Value.ToString("N2")</p>
                        }
                        @if (!string.IsNullOrEmpty(item.PurchasedBy))
                        {
                            <p class="card-text"><small>Comprado por: @item.PurchasedBy em @item.PurchasedDate?.ToShortDateString()</small></p>
                        }
                        <div class="btn-group">
                            <form asp-action="MarkAsPurchased" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-secondary">↶ Marcar como Por Comprar</button>
                            </form>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">
                Não foram encontrados artigos do bebé. <button type="button" class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#createBabyItemModal">Adiciona o teu primeiro artigo!</button>
            </div>
        </div>
    }
</div>

<!-- Modal de Criação de Artigo -->
<div class="modal fade" id="createBabyItemModal" tabindex="-1" aria-labelledby="createBabyItemModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD0 100%);">
                <h5 class="modal-title" id="createBabyItemModalLabel">👶 Novo Artigo do Bebé</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <form hx-post="@Url.Action("CreatePartial", "BabyItems")"
                  hx-target="#babyItemsList"
                  hx-swap="afterbegin"
                  hx-on:htmx:after-request="closeModalAndReset('createBabyItemModal')">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="Name" required maxlength="200" placeholder="Ex: Bodies 0-3M, Carrinho..." />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Prioridade <span class="text-danger">*</span></label>
                            <select class="form-select" name="Priority" required>
                                <option value="1">1 - Muito Alta</option>
                                <option value="2">2 - Alta</option>
                                <option value="3" selected>3 - Média</option>
                                <option value="4">4 - Baixa</option>
                                <option value="5">5 - Muito Baixa</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Categoria</label>
                            <input type="text" class="form-control" name="Category" list="categoryList" placeholder="Ex: Roupa, Quarto..." />
                            <datalist id="categoryList">
                                <option value="Roupa"></option>
                                <option value="Quarto do Bebé"></option>
                                <option value="Alimentação"></option>
                                <option value="Banho"></option>
                                <option value="Fraldas"></option>
                                <option value="Brinquedos"></option>
                                <option value="Segurança"></option>
                                <option value="Viagem"></option>
                            </datalist>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Custo Estimado (€)</label>
                            <div class="input-group">
                                <span class="input-group-text">€</span>
                                <input type="number" class="form-control" name="EstimatedCost" step="0.01" min="0" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Quantidade</label>
                            <input type="number" class="form-control" name="Quantity" value="1" min="1" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Descrição</label>
                            <textarea class="form-control" name="Description" rows="2" maxlength="500"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="IsPurchased" id="isPurchased" />
                                <label class="form-check-label" for="isPurchased">✅ Já Comprado</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle-fill"></i> Adicionar Artigo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
