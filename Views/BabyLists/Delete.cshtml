@model Ervilhinha.Models.BabyList

@{
    ViewData["Title"] = "Eliminar Lista";
}

<div class="mb-4">
    <h1 class="page-title text-danger">🗑️ Eliminar Lista</h1>
    <p class="text-soft mb-0">Tens a certeza que queres eliminar esta lista?</p>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow border-danger">
            <div class="card-body">
                <h5 class="mb-3">@Model.Name</h5>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted">@Model.Description</p>
                }

                <div class="alert alert-warning">
                    <h6>⚠️ Atenção!</h6>
                    <p class="mb-0">
                        Esta ação é <strong>permanente</strong> e irá eliminar:
                    </p>
                    <ul class="mb-0">
                        <li><strong>@Model.Items.Count items</strong> desta lista</li>
                        @if (Model.IsShared)
                        {
                            <li>Todas as <strong>partilhas e reservas</strong></li>
                            <li>O código de partilha <span class="font-monospace">@Model.ShareCode</span></li>
                        }
                    </ul>
                </div>

                <div class="d-flex gap-2">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger">
                            🗑️ Sim, Eliminar Lista
                        </button>
                    </form>
                    <a asp-action="Manage" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
