@model Ervilhinha.Models.BabyListItem

@{
    ViewData["Title"] = "Adicionar Item";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Minhas Listas</a></li>
            <li class="breadcrumb-item"><a asp-action="Manage" asp-route-id="@ViewBag.ListId">@ViewBag.ListName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Adicionar Item</li>
        </ol>
    </nav>
    <h1 class="page-title">📦 Adicionar Item</h1>
    <p class="text-soft mb-0">
        <i class="bi bi-info-circle"></i> Preenche as informações do item que queres adicionar à tua lista
    </p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        <form asp-action="AddItem" method="post" id="addItemForm">
            <input type="hidden" asp-for="BabyListId" value="@ViewBag.ListId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <!-- ========== GRUPO 1: Informação Básica ========== -->
            <div class="card form-card-modern shadow mb-4">
                <div class="card-body">
                    <div class="form-header-decorated">
                        <h5>Informação Básica</h5>
                    </div>

                    <!-- Nome do Item - Floating Label + Ícone -->
                    <div class="form-floating-modern input-with-icon">
                        <input asp-for="Name" 
                               id="Name" 
                               placeholder=" " 
                               class="form-control" 
                               required 
                               maxlength="200" 
                               autofocus />
                        <label for="Name">Nome do Item *</label>
                        <span class="input-icon">📦</span>
                    </div>
                    <div class="form-hint">Ex: Berço de madeira, Pack 5 bodies 0-3M...</div>

                    <!-- Descrição - Floating Label + Ícone -->
                    <div class="form-floating-modern input-with-icon">
                        <textarea asp-for="Description" 
                                  id="Description" 
                                  placeholder=" " 
                                  class="form-control" 
                                  maxlength="1000"></textarea>
                        <label for="Description">Descrição (opcional)</label>
                        <span class="input-icon">💬</span>
                    </div>
                    <div class="form-hint">Detalhes como cor, tamanho, marca preferida...</div>
                </div>
            </div>

            <!-- ========== GRUPO 2: Categorização ========== -->
            <div class="card form-card-modern shadow mb-4">
                <div class="card-body">
                    <div class="form-header-decorated">
                        <h5>Categorização</h5>
                    </div>

                    <div class="row g-3">
                        <!-- Categoria - Com Ícone -->
                        <div class="col-md-6">
                            <div class="input-with-icon">
                                <select asp-for="Category" 
                                        id="Category" 
                                        class="form-select" 
                                        required>
                                    <option value="">Escolha a categoria...</option>
                                    <optgroup label="Essenciais">
                                        <option value="1">🛏️ Quarto do Bebé</option>
                                        <option value="6">🍼 Alimentação</option>
                                        <option value="5">🛁 Higiene e Banho</option>
                                    <option value="7">🚗 Passeio (Carrinho, Cadeira Auto)</option>
                                    <option value="9">🏥 Saúde e Segurança</option>
                                </optgroup>
                                <optgroup label="Roupa por Idade">
                                    <option value="2">👶 Roupa 0-3 Meses</option>
                                    <option value="3">👕 Roupa 3-6 Meses</option>
                                    <option value="4">👔 Roupa 6-12 Meses</option>
                                </optgroup>
                                <optgroup label="Outros">
                                    <option value="8">🧸 Brinquedos</option>
                                    <option value="10">✨ Acessórios</option>
                                    <option value="11">📦 Outros</option>
                                </optgroup>
                            </select>
                            <span asp-validation-for="Category" class="text-danger small"></span>
                        </div>

                        <!-- Prioridade -->
                        <div class="col-md-6">
                            <label asp-for="Priority" class="form-label fw-semibold">
                                Prioridade <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Priority" class="form-select form-select-lg" required>
                                <option value="1" selected>✅ Essencial (Comprar prioritariamente)</option>
                                <option value="2">⭐ Recomendado (Muito útil)</option>
                                <option value="3">💡 Opcional (Se houver orçamento)</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">
                                Ajuda a priorizar o que comprar primeiro
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ========== GRUPO 3: Planeamento Financeiro ========== -->
            <div class="card shadow mb-4">
                <div class="card-header bg-gradient-yellow">
                    <h5 class="mb-0">💰 Planeamento Financeiro</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Quantidade -->
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label asp-for="Quantity" class="form-label fw-semibold">
                                Quantidade <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Quantity" type="number" class="form-control form-control-lg" 
                                   min="1" max="100" value="1" required id="quantityInput" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Min: 1 | Máx: 100</small>
                        </div>

                        <!-- Custo Estimado -->
                        <div class="col-md-4 mb-3 mb-md-0">
                            <label asp-for="EstimatedCost" class="form-label fw-semibold">
                                Custo Estimado <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-success text-white fw-bold">€</span>
                                <input asp-for="EstimatedCost" type="number" class="form-control" 
                                       step="0.01" min="0" max="10000" placeholder="0.00" required 
                                       id="costInput" />
                            </div>
                            <span asp-validation-for="EstimatedCost" class="text-danger small"></span>
                            <small class="text-muted d-block mt-1">Ex: 49.99</small>
                        </div>

                        <!-- Quando Comprar -->
                        <div class="col-md-4">
                            <label asp-for="RecommendedTiming" class="form-label fw-semibold">
                                Quando Comprar <span class="text-muted small">(opcional)</span>
                            </label>
                            <select asp-for="RecommendedTiming" class="form-select form-select-lg">
                                <option value="">-- Quando necessário --</option>
                                <option value="1">📅 Gravidez (até 6 meses)</option>
                                <option value="2">📅 7º Mês de Gravidez</option>
                                <option value="3" selected>📅 8º Mês de Gravidez</option>
                                <option value="4">📅 Antes do Nascimento</option>
                                <option value="5">👶 Logo Após Nascimento</option>
                                <option value="6">👶 Com 3 Meses do Bebé</option>
                                <option value="7">👶 Com 6 Meses do Bebé</option>
                                <option value="8">👶 Com 9 Meses do Bebé</option>
                                <option value="9">⏰ Quando Necessário</option>
                            </select>
                            <small class="text-muted d-block mt-1">
                                Recomendação de quando adquirir
                            </small>
                        </div>
                    </div>

                    <!-- Custo Total Calculado -->
                    <div class="alert alert-info mt-3 mb-0" role="alert">
                        <div class="d-flex align-items-center justify-content-between">
                            <span><strong>💡 Custo Total Estimado:</strong></span>
                            <span class="fs-4 fw-bold text-primary">€ <span id="totalCost">0.00</span></span>
                        </div>
                        <small class="text-muted">Quantidade × Custo Unitário</small>
                    </div>
                </div>
            </div>

            <!-- ========== GRUPO 4: Informações Adicionais ========== -->
            <div class="card shadow mb-4">
                <div class="card-header bg-gradient-pink">
                    <h5 class="mb-0">➕ Informações Adicionais</h5>
                </div>
                <div class="card-body">
                    <!-- Link do Produto -->
                    <div class="mb-3">
                        <label asp-for="ProductUrl" class="form-label fw-semibold">
                            Link do Produto <span class="text-muted small">(opcional)</span>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-primary text-white">
                                <i class="bi bi-link-45deg"></i>
                            </span>
                            <input asp-for="ProductUrl" type="url" class="form-control" 
                                   placeholder="https://www.loja.com/produto" maxlength="500" />
                        </div>
                        <span asp-validation-for="ProductUrl" class="text-danger small"></span>
                        <small class="text-muted d-block mt-1">
                            <i class="bi bi-info-circle"></i> Link para o produto numa loja online (ex: Amazon, Chicco, Prenatal)
                        </small>
                    </div>

                    <!-- Notas -->
                    <div class="mb-0">
                        <label asp-for="Notes" class="form-label fw-semibold">
                            Notas <span class="text-muted small">(opcional)</span>
                        </label>
                        <textarea asp-for="Notes" class="form-control" rows="2" 
                                  maxlength="1000" id="notesInput"
                                  placeholder="Observações adicionais, preferências de cor/marca, alternativas..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                        <small class="text-muted">Máximo 1000 caracteres</small>
                    </div>
                </div>
            </div>

            <!-- ========== BOTÕES DE AÇÃO ========== -->
            <div class="d-flex gap-2 justify-content-between align-items-center">
                <a asp-action="Manage" asp-route-id="@ViewBag.ListId" 
                   class="btn btn-outline-secondary btn-lg" id="cancelBtn">
                    <i class="bi bi-x-circle"></i> Cancelar
                </a>
                <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                    <i class="bi bi-plus-circle-fill"></i> Adicionar Item
                </button>
            </div>

            <!-- Helper Text -->
            <div class="text-center mt-3">
                <small class="text-muted">
                    <i class="bi bi-lightbulb"></i> Podes editar ou eliminar este item depois de adicionar
                </small>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Character counters
        const nameInput = document.getElementById('itemNameInput');
        const nameCount = document.getElementById('nameCharCount');
        const descInput = document.getElementById('descriptionInput');
        const descCount = document.getElementById('descCharCount');
        const notesInput = document.getElementById('notesInput');

        nameInput.addEventListener('input', function() {
            nameCount.textContent = this.value.length;
        });

        descInput.addEventListener('input', function() {
            descCount.textContent = this.value.length;
        });

        // Auto-resize textarea
        [descInput, notesInput].forEach(textarea => {
            textarea.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = this.scrollHeight + 'px';
            });
        });

        // Calculate total cost
        const quantityInput = document.getElementById('quantityInput');
        const costInput = document.getElementById('costInput');
        const totalCostSpan = document.getElementById('totalCost');

        function updateTotalCost() {
            const qty = parseFloat(quantityInput.value) || 0;
            const cost = parseFloat(costInput.value) || 0;
            const total = qty * cost;
            totalCostSpan.textContent = total.toFixed(2);
        }

        quantityInput.addEventListener('input', updateTotalCost);
        costInput.addEventListener('input', updateTotalCost);

        // Format cost on blur
        costInput.addEventListener('blur', function() {
            if (this.value) {
                this.value = parseFloat(this.value).toFixed(2);
                updateTotalCost();
            }
        });

        // Confirm cancel if form has data
        const form = document.getElementById('addItemForm');
        const cancelBtn = document.getElementById('cancelBtn');

        cancelBtn.addEventListener('click', function(e) {
            const hasData = nameInput.value.trim() !== '' || 
                           descInput.value.trim() !== '' || 
                           costInput.value.trim() !== '';

            if (hasData) {
                if (!confirm('Tens dados não guardados. Tens a certeza que queres cancelar?')) {
                    e.preventDefault();
                }
            }
        });

        // Submit button loading state
        form.addEventListener('submit', function(e) {
            if (form.checkValidity()) {
                const submitBtn = document.getElementById('submitBtn');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> A adicionar item...';
            }
        });

        // Smart category selection helper
        const categorySelect = document.getElementById('categorySelect');
        nameInput.addEventListener('blur', function() {
            if (!categorySelect.value && this.value) {
                const name = this.value.toLowerCase();
                // Auto-suggest category based on keywords
                if (name.includes('berço') || name.includes('cómoda') || name.includes('móbile')) {
                    categorySelect.value = '1'; // Quarto
                } else if (name.includes('body') || name.includes('babygrow') || name.includes('meia')) {
                    categorySelect.value = '2'; // Roupa 0-3M
                } else if (name.includes('biberão') || name.includes('biberao') || name.includes('tetina')) {
                    categorySelect.value = '6'; // Alimentação
                } else if (name.includes('fralda') || name.includes('toalha') || name.includes('banheira')) {
                    categorySelect.value = '5'; // Higiene
                } else if (name.includes('carrinho') || name.includes('cadeira auto')) {
                    categorySelect.value = '7'; // Passeio
                }

                if (categorySelect.value) {
                    categorySelect.classList.add('highlight-suggest');
                    setTimeout(() => categorySelect.classList.remove('highlight-suggest'), 2000);
                }
            }
        });
    </script>

    <style>
        /* Gradient headers */
        .bg-gradient-pea {
            background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
        }

        .bg-gradient-pink {
            background: linear-gradient(135deg, #FCE4EC 0%, #F8BBD0 100%);
        }

        .bg-gradient-blue {
            background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
        }

        .bg-gradient-yellow {
            background: linear-gradient(135deg, #FFF9C4 0%, #FFF59D 100%);
        }

        /* Number input spinners */
        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            opacity: 1;
            height: 30px;
        }

        /* Highlight suggestion */
        .highlight-suggest {
            animation: pulse-border 1s ease-in-out 2;
            box-shadow: 0 0 0 3px rgba(165, 214, 167, 0.5);
        }

        @@keyframes pulse-border {
            0%, 100% { box-shadow: 0 0 0 0 rgba(165, 214, 167, 0.5); }
            50% { box-shadow: 0 0 0 8px rgba(165, 214, 167, 0); }
        }
    </style>
}

