@model Ervilhinha.Models.ExpenseCategory

@{
    ViewData["Title"] = "Criar Categoria";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Início</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Categorias</a></li>
            <li class="breadcrumb-item active">Criar</li>
        </ol>
    </nav>
    <h1 class="page-title">➕ Criar Categoria de Despesa</h1>
    <p class="text-soft mb-0"><i class="bi bi-info-circle"></i> Cria uma nova categoria para organizar as tuas despesas</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="row">
            <div class="col-lg-7">
                <form asp-action="Create" method="post" id="createCategoryForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="card shadow mb-4">
                        <div class="card-header" style="background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);">
                            <h5 class="mb-0">📝 Informações da Categoria</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-semibold">
                                    Nome <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Name" class="form-control form-control-lg" 
                                       placeholder="Ex: Alimentação, Transporte, Saúde..." 
                                       autofocus required maxlength="50" id="nameInput" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                                <small class="text-muted"><span id="nameCharCount">0</span> / 50 caracteres</small>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Color" class="form-label fw-semibold">
                                    Cor <span class="text-muted small">(opcional)</span>
                                </label>
                                <div class="row g-2">
                                    <div class="col-auto">
                                        <input asp-for="Color" type="color" class="form-control form-control-color" 
                                               style="width: 70px; height: 50px;" id="colorPicker" value="#4CAF50" />
                                    </div>
                                    <div class="col">
                                        <input asp-for="Color" type="text" class="form-control form-control-lg" 
                                               placeholder="#4CAF50" maxlength="7" id="colorInput" value="#4CAF50" />
                                    </div>
                                </div>
                                <span asp-validation-for="Color" class="text-danger small"></span>
                                <small class="text-muted">Cor para gráficos e visualizações</small>
                            </div>

                            <div class="form-check form-switch form-switch-lg">
                                <input asp-for="IsActive" class="form-check-input" 
                                       type="checkbox" role="switch" id="activeToggle" checked />
                                <label class="form-check-label fw-semibold" for="activeToggle">
                                    <span class="fs-5">✅</span> Categoria Ativa
                                </label>
                            </div>
                            <small class="text-muted d-block ms-5">Apenas categorias ativas aparecem na criação de despesas</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                            <i class="bi bi-check-circle-fill"></i> Criar Categoria
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-lg-5 mt-4 mt-lg-0">
                <div class="card shadow sticky-top" style="top: 1rem;">
                    <div class="card-header bg-info bg-opacity-10">
                        <h6 class="mb-0 text-info"><i class="bi bi-lightbulb-fill"></i> Sugestões de Categorias</h6>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Bebé" data-icon="🍼" data-color="#FF69B4">
                                <span class="fs-4">🍼</span> <strong>Bebé</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #FF69B4;">Preview</span>
                            </button>
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Casa" data-icon="🏠" data-color="#4CAF50">
                                <span class="fs-4">🏠</span> <strong>Casa</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #4CAF50;">Preview</span>
                            </button>
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Transporte" data-icon="🚗" data-color="#2196F3">
                                <span class="fs-4">🚗</span> <strong>Transporte</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #2196F3;">Preview</span>
                            </button>
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Supermercado" data-icon="🛒" data-color="#FF9800">
                                <span class="fs-4">🛒</span> <strong>Supermercado</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #FF9800;">Preview</span>
                            </button>
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Contas" data-icon="⚡" data-color="#9C27B0">
                                <span class="fs-4">⚡</span> <strong>Contas</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #9C27B0;">Preview</span>
                            </button>
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Saúde" data-icon="💊" data-color="#F44336">
                                <span class="fs-4">💊</span> <strong>Saúde</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #F44336;">Preview</span>
                            </button>
                            <button type="button" class="list-group-item list-group-item-action category-suggestion" 
                                    data-name="Lazer" data-icon="🎉" data-color="#00BCD4">
                                <span class="fs-4">🎉</span> <strong>Lazer</strong>
                                <span class="badge rounded-pill float-end" style="background-color: #00BCD4;">Preview</span>
                            </button>
                        </div>
                        <small class="text-muted d-block mt-3"><i class="bi bi-hand-index"></i> Clica numa sugestão para preencher automaticamente</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        const nameInput = document.getElementById('nameInput');
        const nameCount = document.getElementById('nameCharCount');
        const colorPicker = document.getElementById('colorPicker');
        const colorInput = document.getElementById('colorInput');

        nameInput.addEventListener('input', () => nameCount.textContent = nameInput.value.length);

        colorPicker.addEventListener('input', function() {
            colorInput.value = this.value.toUpperCase();
        });

        colorInput.addEventListener('input', function() {
            if (/^#[0-9A-F]{6}$/i.test(this.value)) {
                colorPicker.value = this.value;
            }
        });

        document.querySelectorAll('.category-suggestion').forEach(btn => {
            btn.addEventListener('click', function() {
                nameInput.value = this.dataset.name;
                colorInput.value = this.dataset.color;
                colorPicker.value = this.dataset.color;

                nameCount.textContent = nameInput.value.length;

                this.classList.add('active');
                setTimeout(() => this.classList.remove('active'), 1000);

                nameInput.focus();
            });
        });

        const form = document.getElementById('createCategoryForm');
        form.addEventListener('submit', function() {
            if (form.checkValidity()) {
                const submitBtn = document.getElementById('submitBtn');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> A criar...';
            }
        });
    </script>

    <style>
        .form-switch-lg .form-check-input {
            width: 3rem;
            height: 1.5rem;
        }
        .category-suggestion.active {
            background-color: #d4edda !important;
        }
    </style>
}
