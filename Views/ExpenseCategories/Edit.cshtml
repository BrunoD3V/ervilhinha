@model Ervilhinha.Models.ExpenseCategory

@{
    ViewData["Title"] = "Editar Categoria";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Início</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Categorias</a></li>
            <li class="breadcrumb-item active">Editar</li>
        </ol>
    </nav>
    <h1 class="page-title">✏️ Editar Categoria</h1>
    <p class="text-soft mb-0"><i class="bi bi-info-circle"></i> Atualiza a categoria <strong>@Model.Name</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="row">
            <div class="col-lg-7">
                <form asp-action="Edit" method="post" id="editCategoryForm">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="card shadow mb-4">
                        <div class="card-header" style="background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);">
                            <h5 class="mb-0">📝 Informações da Categoria</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-4">
                                <label asp-for="Name" class="form-label fw-semibold">
                                    Nome <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Name" class="form-control form-control-lg" 
                                       autofocus required maxlength="50" id="nameInput" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                                <small class="text-muted"><span id="nameCharCount">@(Model.Name?.Length ?? 0)</span> / 50 caracteres</small>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Color" class="form-label fw-semibold">
                                    Cor <span class="text-muted small">(opcional)</span>
                                </label>
                                <div class="row g-2">
                                    <div class="col-auto">
                                        <input asp-for="Color" type="color" class="form-control form-control-color" 
                                               style="width: 70px; height: 50px;" id="colorPicker" />
                                    </div>
                                    <div class="col">
                                        <input asp-for="Color" type="text" class="form-control form-control-lg" 
                                               maxlength="7" id="colorInput" />
                                    </div>
                                </div>
                                <span asp-validation-for="Color" class="text-danger small"></span>
                            </div>

                            <div class="form-check form-switch form-switch-lg">
                                <input asp-for="IsActive" class="form-check-input" 
                                       type="checkbox" role="switch" id="activeToggle" />
                                <label class="form-check-label fw-semibold" for="activeToggle">
                                    <span class="fs-5">@(Model.IsActive ? "✅" : "❌")</span> Categoria Ativa
                                </label>
                            </div>
                            <small class="text-muted d-block ms-5">Apenas categorias ativas aparecem na criação de despesas</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg" id="cancelBtn">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5" id="submitBtn">
                            <i class="bi bi-check-circle-fill"></i> Guardar Alterações
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-lg-5 mt-4 mt-lg-0">
                <div class="card shadow sticky-top" style="top: 1rem;">
                    <div class="card-header bg-info bg-opacity-10">
                        <h6 class="mb-0 text-info"><i class="bi bi-eye-fill"></i> Pré-visualização</h6>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <h2>
                                <span class="badge" id="previewBadge" style="background-color: @Model.Color">
                                    <span id="previewName">@Model.Name</span>
                                </span>
                            </h2>
                        </div>
                        <p class="text-muted small text-center">Esta é a aparência da categoria nos relatórios e gráficos</p>

                        <hr>

                        <div class="alert alert-info small mb-0">
                            <strong><i class="bi bi-info-circle"></i> Dica:</strong>
                            As alterações na pré-visualização aparecem em tempo real conforme editas os campos.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        const nameInput = document.getElementById('nameInput');
        const nameCount = document.getElementById('nameCharCount');
        const colorPicker = document.getElementById('colorPicker');
        const colorInput = document.getElementById('colorInput');
        const previewBadge = document.getElementById('previewBadge');
        const previewName = document.getElementById('previewName');

        nameInput.addEventListener('input', function() {
            nameCount.textContent = this.value.length;
            previewName.textContent = this.value || 'Nome';
        });

        colorPicker.addEventListener('input', function() {
            colorInput.value = this.value.toUpperCase();
            previewBadge.style.backgroundColor = this.value;
        });

        colorInput.addEventListener('input', function() {
            if (/^#[0-9A-F]{6}$/i.test(this.value)) {
                colorPicker.value = this.value;
                previewBadge.style.backgroundColor = this.value;
            }
        });

        const form = document.getElementById('editCategoryForm');
        const cancelBtn = document.getElementById('cancelBtn');
        const originalData = new FormData(form);

        cancelBtn.addEventListener('click', function(e) {
            const currentData = new FormData(form);
            let isModified = false;

            for (let [key, value] of currentData.entries()) {
                if (originalData.get(key) !== value) {
                    isModified = true;
                    break;
                }
            }

            if (isModified && !confirm('Tens alterações não guardadas. Tens a certeza?')) {
                e.preventDefault();
            }
        });

        form.addEventListener('submit', function() {
            if (form.checkValidity()) {
                const submitBtn = document.getElementById('submitBtn');
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> A guardar...';
            }
        });
    </script>

    <style>
        .form-switch-lg .form-check-input {
            width: 3rem;
            height: 1.5rem;
        }
    </style>
}
