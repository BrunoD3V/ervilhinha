@{
    ViewData["Title"] = "Lista Não Encontrada";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-yellow shadow text-center p-5">
            <div class="card-body">
                <div class="mb-4">
                    <svg width="120" height="120" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="50" cy="50" r="45" fill="#f4d19b" opacity="0.3"/>
                        <text x="50" y="70" font-size="60" text-anchor="middle">🔍</text>
                    </svg>
                </div>

                <h1 class="display-4 mb-3">Lista Não Encontrada</h1>
                <p class="lead mb-4">@ViewBag.ErrorMessage</p>

                <div class="alert alert-warning text-start">
                    <h6>🤔 Possíveis Razões:</h6>
                    <ul class="mb-0">
                        <li>O código pode estar incorreto (verifica espaços ou hífens)</li>
                        <li>A lista pode ter sido eliminada pelo criador</li>
                        <li>O link pode estar desatualizado</li>
                    </ul>
                </div>

                <h5 class="mt-4 mb-3">Tens um código de acesso?</h5>
                <form asp-controller="WishlistPublic" asp-action="View" method="get" class="mb-4">
                    <div class="input-group input-group-lg">
                        <input type="text" name="code" class="form-control" placeholder="ABC-DEF-GHI" required />
                        <button type="submit" class="btn btn-primary">Aceder</button>
                    </div>
                    <small class="text-soft">Introduz o código de partilha que recebeste</small>
                </form>

                <hr class="my-4" />

                <div class="d-grid gap-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
                        🏠 Voltar à Página Inicial
                    </a>
                    <a asp-controller="Wishlist" asp-action="MyLists" class="btn btn-outline-secondary">
                        Criar Minha Própria Lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
