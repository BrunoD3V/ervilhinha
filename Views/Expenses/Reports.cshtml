@model Ervilhinha.Models.ReportsViewModel

@{
    ViewData["Title"] = "Expense Reports";
}

<h1>📊 Expense Reports</h1>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h3>Grand Total</h3>
            </div>
            <div class="card-body text-center">
                <h1 class="display-4">$@Model.GrandTotal.ToString("N2")</h1>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h4>📈 Expenses by Category</h4>
            </div>
            <div class="card-body">
                <canvas id="categoryChart" height="300"></canvas>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <h4>Category Details</h4>
            </div>
            <div class="card-body">
                @if (Model.CategoryTotals.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Category</th>
                                    <th>Count</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CategoryTotals)
                                {
                                    <tr>
                                        <td>@item.Category</td>
                                        <td>@item.Count</td>
                                        <td><strong>$@item.Total.ToString("N2")</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No expense data available.</p>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h4>📅 Monthly Trends</h4>
            </div>
            <div class="card-body">
                <canvas id="monthlyChart" height="300"></canvas>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header">
                <h4>Monthly Totals</h4>
            </div>
            <div class="card-body">
                @if (Model.MonthlyTotals.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Month</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.MonthlyTotals)
                                {
                                    <tr>
                                        <td>@(new DateTime(item.Year, item.Month, 1).ToString("MMMM yyyy"))</td>
                                        <td><strong>$@item.Total.ToString("N2")</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No expense data available.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to Expenses</a>
</div>

@section Scripts {
    <script>
        // Category Chart (Pie)
        const categoryData = {
            labels: [@Html.Raw(string.Join(",", Model.CategoryTotals.Select(x => $"'{x.Category}'")))],
            datasets: [{
                label: 'Expenses by Category',
                data: [@Html.Raw(string.Join(",", Model.CategoryTotals.Select(x => x.Total)))],
                backgroundColor: [
                    'rgba(255, 99, 132, 0.7)',
                    'rgba(54, 162, 235, 0.7)',
                    'rgba(255, 206, 86, 0.7)',
                    'rgba(75, 192, 192, 0.7)',
                    'rgba(153, 102, 255, 0.7)',
                    'rgba(255, 159, 64, 0.7)',
                    'rgba(99, 255, 132, 0.7)',
                    'rgba(235, 54, 162, 0.7)'
                ],
                borderColor: [
                    'rgba(255, 99, 132, 1)',
                    'rgba(54, 162, 235, 1)',
                    'rgba(255, 206, 86, 1)',
                    'rgba(75, 192, 192, 1)',
                    'rgba(153, 102, 255, 1)',
                    'rgba(255, 159, 64, 1)',
                    'rgba(99, 255, 132, 1)',
                    'rgba(235, 54, 162, 1)'
                ],
                borderWidth: 2
            }]
        };

        const categoryChart = new Chart(
            document.getElementById('categoryChart'),
            {
                type: 'doughnut',
                data: categoryData,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.label + ': $' + context.parsed.toFixed(2);
                                }
                            }
                        }
                    }
                }
            }
        );

        // Monthly Chart (Bar)
        const monthlyData = {
            labels: [@Html.Raw(string.Join(",", Model.MonthlyTotals.Take(12).Select(x => $"'{new DateTime(x.Year, x.Month, 1).ToString("MMM yyyy")}'")))],
            datasets: [{
                label: 'Monthly Spending',
                data: [@Html.Raw(string.Join(",", Model.MonthlyTotals.Take(12).Select(x => x.Total)))],
                backgroundColor: 'rgba(78, 205, 196, 0.7)',
                borderColor: 'rgba(78, 205, 196, 1)',
                borderWidth: 2
            }]
        };

        const monthlyChart = new Chart(
            document.getElementById('monthlyChart'),
            {
                type: 'bar',
                data: monthlyData,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toFixed(2);
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return 'Total: $' + context.parsed.y.toFixed(2);
                                }
                            }
                        }
                    }
                }
            }
        );
    </script>
}
