@model IEnumerable<Ervilhinha.Models.Expense>

@{
    ViewData["Title"] = "Despesas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>💰 Despesas</h1>
    <a asp-action="Create" class="btn btn-primary">➕ Adicionar Nova Despesa</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Categoria</label>
                <select name="categoryId" class="form-select">
                    <option value="">Todas as Categorias</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.SelectedCategory == cat.Id)">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Data Início</label>
                <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Data Fim</label>
                <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-info">
    <h4>Total: €@ViewBag.TotalAmount.ToString("N2")</h4>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Descrição</th>
                    <th>Categoria</th>
                    <th>Montante</th>
                    <th>Criado Por</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in Model)
                {
                    <tr>
                        <td>@expense.Date.ToShortDateString()</td>
                        <td>
                            @expense.Description
                            @if (!string.IsNullOrEmpty(expense.Notes))
                            {
                                <br /><small class="text-muted">@expense.Notes</small>
                            }
                        </td>
                        <td><span class="badge" style="background-color: @expense.ExpenseCategory?.Color">@expense.ExpenseCategory?.Name</span></td>
                        <td><strong>€@expense.Amount.ToString("N2")</strong></td>
                        <td>@expense.CreatedBy</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-warning">Editar</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-danger">Eliminar</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        Não foram encontradas despesas. <a asp-action="Create">Adiciona a tua primeira despesa!</a>
    </div>
}
