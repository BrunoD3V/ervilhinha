@model IEnumerable<Ervilhinha.Models.Expense>

@{
    ViewData["Title"] = "Despesas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>💰 Despesas</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createExpenseModal">
        ➕ Adicionar Nova Despesa
    </button>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Categoria</label>
                <select name="categoryId" class="form-select">
                    <option value="">Todas as Categorias</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.SelectedCategory == cat.Id)">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Data Início</label>
                <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Data Fim</label>
                <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-info">
    <h4>Total: €@ViewBag.TotalAmount.ToString("N2")</h4>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Descrição</th>
                    <th>Categoria</th>
                    <th>Montante</th>
                    <th>Criado Por</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody id="expensesList">
                @foreach (var expense in Model)
                {
                    <tr>
                        <td>@expense.Date.ToShortDateString()</td>
                        <td>
                            @expense.Description
                            @if (!string.IsNullOrEmpty(expense.Notes))
                            {
                                <br /><small class="text-muted">@expense.Notes</small>
                            }
                        </td>
                        <td><span class="badge" style="background-color: @expense.ExpenseCategory?.Color">@expense.ExpenseCategory?.Name</span></td>
                        <td><strong>€@expense.Amount.ToString("N2")</strong></td>
                        <td>@expense.CreatedBy</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@expense.Id" class="btn btn-warning">Editar</a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@expense.Id" class="btn btn-danger">Eliminar</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        Não foram encontradas despesas. <button type="button" class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#createExpenseModal">Adiciona a tua primeira despesa!</button>
    </div>
}

<!-- Modal de Criação de Despesa -->
<div class="modal fade" id="createExpenseModal" tabindex="-1" aria-labelledby="createExpenseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);">
                <h5 class="modal-title" id="createExpenseModalLabel">💰 Nova Despesa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <form hx-post="@Url.Action("CreatePartial", "Expenses")" 
                  hx-target="#expensesList" 
                  hx-swap="afterbegin"
                  hx-on:htmx:after-request="closeModalAndReset('createExpenseModal')">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="expenseDescription" class="form-label fw-semibold">Descrição <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="expenseDescription" name="Description" required maxlength="200" placeholder="Ex: Supermercado Continente..." />
                        </div>
                        <div class="col-md-6">
                            <label for="expenseAmount" class="form-label fw-semibold">Montante <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-danger text-white fw-bold">€</span>
                                <input type="number" class="form-control" id="expenseAmount" name="Amount" step="0.01" min="0" required placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label for="expenseDate" class="form-label fw-semibold">Data <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="expenseDate" name="Date" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12">
                            <label for="expenseCategory" class="form-label fw-semibold">Categoria <span class="text-danger">*</span></label>
                            <select class="form-select" id="expenseCategory" name="ExpenseCategoryId" required>
                                <option value="">-- Seleciona uma categoria --</option>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="expenseNotes" class="form-label fw-semibold">Notas <span class="text-muted small">(opcional)</span></label>
                            <textarea class="form-control" id="expenseNotes" name="Notes" rows="2" maxlength="500" placeholder="Observações adicionais..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle-fill"></i> Adicionar Despesa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .htmx-request .htmx-indicator {
            display: inline-block;
        }
        .htmx-indicator {
            display: none;
        }
    </style>
}
